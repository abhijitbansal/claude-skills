# Linear PM config for this repo.
# Generated by /linear-init. Safe to commit.

team: REPLACE_TEAM_KEY                 # e.g. ABH
project: REPLACE_PROJECT_NAME          # e.g. Paperix

branch_prefix: agent/
pr_title_format: "{key}: {title}"

# Autonomy policy:
#   disabled    — skill is read-only against Linear, never touches code
#   review-only — skill writes to Linear (status, comments), never touches code
#   allowed     — full /linear-pick loop: branches, PRs
autonomy: review-only

# Commands /linear-pick must run green before opening a PR.
# Each is a shell command run from repo root; non-zero exit = agent-blocked.
# Use block-style for non-empty lists; inline [a, b] is not parsed.
verify: []

# Hard self-block above this diff size (added + removed lines).
max_pr_lines: 500

# Labels added to every issue created via /linear-new from this repo.
# Use block-style for non-empty lists; inline [a, b] is not parsed.
default_labels: []

# Polling agent picks up from this repo when enabled.
poll:
  enabled: false
  interval_minutes: 15
